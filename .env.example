# --- Server-only secrets (set these in the Vercel dashboard → Project → Settings → Environment Variables) ---
# These are read by the serverless functions in /api and are NEVER exposed to the browser.

# NVIDIA NIM API key — powers Elmarie (/api/elmarie) and CV parsing (/api/parse-cv).
# Get one at https://build.nvidia.com → your account → "API key".
NVIDIA_API_KEY="nvapi-xxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: override the NVIDIA NIM model (OpenAI-compatible chat model).
# Defaults to meta/llama-3.3-70b-instruct.
# NVIDIA_MODEL="meta/llama-3.3-70b-instruct"
